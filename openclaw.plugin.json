{
  "id": "claw-sticker",
  "activation": {
    "onStartup": true
  },
  "name": "Claw Sticker",
  "description": "Adds an agentic send_sticker tool with self-contained WeCom sticker delivery.",
  "runtimeExtensions": ["./dist/index.js"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "channels": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["wecom"]
      },
      "mediaBasePath": {
        "type": "string",
        "default": "{workspaceDir}/stickers"
      },
      "assetSync": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true }
        }
      },
      "tool": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true }
        }
      },
      "formatGuard": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true }
        }
      },
      "autoAppend": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "dryRun": { "type": "boolean", "default": false },
          "maxTextLength": { "type": "number", "default": 500 },
          "cooldownMs": { "type": "number", "default": 900000 },
          "minAssistantMessagesBetweenStickers": { "type": "number", "default": 4 }
        }
      }
    }
  },
  "contracts": {
    "tools": ["send_sticker"]
  }
}
